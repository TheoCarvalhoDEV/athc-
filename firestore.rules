rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função auxiliar para verificar autenticação básica
    function isAuthed() {
      return request.auth != null;
    }

    // Função auxiliar para verificar se o usuário é administrador
    function isAdmin() {
      // Verifica via Custom Claims (definido pela Cloud Function setAdminClaim)
      // Fallback por e-mail será mantido temporariamente
      return isAuthed() && (
        ('admin' in request.auth.token && request.auth.token.admin == true) ||
        request.auth.token.email.lower() in [
          'admin@atche.com.br', 
          'theotheteo@gmail.com', 
          'allanjipa123@gmail.com'
        ]
      );
    }

    // Função auxiliar para verificar se o usuário é parceiro ou administrador
    function isPartnerOrAdmin() {
      return isAuthed() && (
        isAdmin() || 
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.type in ['atletica', 'estabelecimento', 'admin']
      );
    }

    match /profiles/{profileId} {
      // Perfis são públicos para visualização
      allow read: if true;
      
      // Permitir criação se o próprio usuário estiver criando seu perfil com tipo 'user'
      // ou se o solicitante for um administrador
      allow create: if isAuthed() && (
        (request.auth.uid == profileId && request.resource.data.type == 'user') || 
        isAdmin()
      );
      
      // Permitir atualização ao dono se não alterar tipo, e-mail ou mustChangePassword,
      // ou se for um administrador
      allow update: if isAuthed() && (
        (
          request.auth.uid == profileId && 
          request.resource.data.type == resource.data.type && 
          request.resource.data.email == resource.data.email &&
          (
            !('mustChangePassword' in request.resource.data) || 
            request.resource.data.mustChangePassword == resource.data.mustChangePassword
          )
        ) || 
        isAdmin()
      );

      // Apenas admins podem deletar perfis
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      // Eventos são públicos para visualização
      allow read: if true;
      // Somente parceiros ou administradores podem criar eventos, e o creatorId deve ser o próprio UID
      allow create: if isPartnerOrAdmin() && request.resource.data.creatorId == request.auth.uid;
      // Somente o criador do evento ou o administrador podem editar/excluir
      allow update, delete: if isAuthed() && (resource.data.creatorId == request.auth.uid || isAdmin());
    }

    match /registrations/{registrationId} {
      // Uma inscrição só pode ser lida se:
      // 1. O solicitante for administrador
      // 2. O solicitante for o dono da inscrição (userId)
      // 3. O solicitante for o criador do evento associado
      allow read: if isAuthed() && (
        resource.data.userId == request.auth.uid ||
        isAdmin() ||
        (
          exists(/databases/$(database)/documents/events/$(resource.data.eventId)) &&
          get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.creatorId == request.auth.uid
        )
      );
      // Qualquer um pode criar inscrições, mas:
      // 1. Se for visitante sem login, validamos os campos obrigatórios.
      // 2. O status de pagamento não pode ser gravado como 'Pago' (apenas 'Gratuito' ou nulo é permitido via cliente)
      allow create: if (isAuthed() || (
        request.resource.data.eventId != null &&
        request.resource.data.userName != null &&
        request.resource.data.userEmail != null &&
        request.resource.data.userName is string && request.resource.data.userName.size() > 0 &&
        request.resource.data.userEmail is string && request.resource.data.userEmail.size() > 0
      )) && (
        !('paymentStatus' in request.resource.data) || 
        request.resource.data.paymentStatus == 'Gratuito' || 
        request.resource.data.paymentStatus == null
      );
      // Apenas administradores podem modificar ou deletar inscrições
      allow update, delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      // Um pedido pode ser lido pelo dono do pedido, pelo admin, ou pelo criador do evento
      // associado (necessário para o painel financeiro do parceiro). CPF/e-mail continuam
      // protegidos de qualquer outro usuário.
      allow read: if isAuthed() && (
        resource.data.userId == request.auth.uid ||
        isAdmin() ||
        (
          exists(/databases/$(database)/documents/events/$(resource.data.eventId)) &&
          get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.creatorId == request.auth.uid
        )
      );
      // Escrita direta pelo cliente é proibida (apenas Cloud Functions do backend criam/alteram)
      allow write: if false;
    }

    // Tokens de push (FCM): cada dispositivo registra seu próprio token vinculado ao seu UID.
    // A leitura é feita exclusivamente pelo backend (Admin SDK) ao enviar notificações.
    match /fcmTokens/{token} {
      allow read: if false;
      // O usuário só pode criar/atualizar um token apontando para o seu próprio UID.
      allow create, update: if isAuthed() && request.resource.data.userId == request.auth.uid;
      // O dono do token pode removê-lo (ex.: ao desativar notificações ou sair).
      allow delete: if isAuthed() && resource.data.userId == request.auth.uid;
    }

    // Coleção interna de rate limiting — acesso bloqueado para clientes
    // Somente Cloud Functions (Admin SDK) podem ler/escrever
    match /_rateLimits/{docId} {
      allow read, write: if false;
    }
  }
}
