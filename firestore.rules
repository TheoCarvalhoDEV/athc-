rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função auxiliar para verificar autenticação básica
    function isAuthed() {
      return request.auth != null;
    }

    // Função auxiliar para verificar se o usuário é administrador
    function isAdmin() {
      // Verifica via Custom Claims (definido pela Cloud Function setAdminClaim)
      // Fallback por e-mail será mantido temporariamente
      return isAuthed() && (
        ('admin' in request.auth.token && request.auth.token.admin == true) ||
        request.auth.token.email.lower() in [
          'admin@atche.com.br', 
          'theotheteo@gmail.com', 
          'allanjipa123@gmail.com'
        ]
      );
    }

    match /profiles/{profileId} {
      // Perfis são públicos para visualização
      allow read: if true;
      // Permite escrita apenas ao próprio dono do perfil ou a administradores
      allow write: if isAuthed() && (request.auth.uid == profileId || isAdmin());
    }

    match /events/{eventId} {
      // Eventos são públicos para visualização
      allow read: if true;
      // Somente usuários logados podem criar eventos
      allow create: if isAuthed();
      // Somente o criador do evento ou o administrador podem editar/excluir
      allow update, delete: if isAuthed() && (resource.data.creatorId == request.auth.uid || isAdmin());
    }

    match /registrations/{registrationId} {
      // Uma inscrição só pode ser lida se:
      // 1. O solicitante for administrador
      // 2. O solicitante for o dono da inscrição (userId)
      // 3. O solicitante for o criador do evento associado
      allow read: if isAuthed() && (
        resource.data.userId == request.auth.uid || 
        isAdmin() || 
        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.creatorId == request.auth.uid
      );
      // Qualquer um pode criar inscrições, mas para visitantes sem login
      // validamos que campos essenciais (nome, email, eventId) são enviados e válidos
      allow create: if isAuthed() || (
        request.resource.data.eventId != null &&
        request.resource.data.userName != null &&
        request.resource.data.userEmail != null &&
        request.resource.data.userName is string && request.resource.data.userName.size() > 0 &&
        request.resource.data.userEmail is string && request.resource.data.userEmail.size() > 0
      );
      // Apenas administradores podem modificar ou deletar inscrições
      allow update, delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      // Um pedido pode ser lido pelo dono do pedido ou admin para proteger CPF/e-mail
      allow read: if isAuthed() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      // Escrita direta pelo cliente é proibida (apenas Cloud Functions do backend criam/alteram)
      allow write: if false;
    }
  }
}
