rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Função auxiliar para verificar se o usuário é administrador
    function isAdmin() {
      return request.auth != null && 
        request.auth.token.email.lower() in [
          'admin@atche.com.br', 
          'theotheteo@gmail.com', 
          'allanjipa123@gmail.com'
        ];
    }

    // Regra para fotos de perfil
    match /profiles/{userId}/{fileName} {
      allow read: if true;
      // Apenas o próprio usuário ou administradores podem subir/alterar fotos
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin()) && request.resource.size < 15 * 1024 * 1024;
    }

    // Regra para fotos/mídias de eventos
    match /events/{userId}/{fileName} {
      allow read: if true;
      // Apenas o próprio criador do evento ou administradores podem subir/alterar fotos
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin()) && request.resource.size < 15 * 1024 * 1024;
    }
  }
}
