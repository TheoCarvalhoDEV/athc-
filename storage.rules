rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Qualquer pessoa pode ver as imagens dos eventos
      allow read: if true;
      
      // Apenas usuários autenticados podem fazer upload de mídia
      // Impede upload de arquivos maiores que 15MB
      allow write: if request.auth != null && request.resource.size < 15 * 1024 * 1024;
    }
  }
}
